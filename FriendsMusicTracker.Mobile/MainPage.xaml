<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FriendsMusicTracker.Mobile"
             xmlns:components="clr-namespace:FriendsMusicTracker.Mobile.Components"
             x:Class="FriendsMusicTracker.Mobile.MainPage">

    <ContentPage.Padding>
        <OnPlatform x:TypeArguments="Thickness">
            <On Platform="Android" Value="0, 25, 0, 0" />
            <On Platform="iOS" Value="0, 45, 0, 0" />
        </OnPlatform>
    </ContentPage.Padding>

    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>