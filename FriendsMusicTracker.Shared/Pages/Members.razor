@page "/members"
@using FriendsMusicTracker.Models
@using System.Net.Http.Json
@inject HttpClient Http

<div class="container mt-4">
    <h3 class="mb-4">👥 F.R.I.E.N.D.S Member Profiles</h3>

    @* Error display panel just in case the network connection drops *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="background: #fff0f0; color: #d92121; padding: 15px; margin-bottom: 25px; border-radius: 8px; font-size: 14px; border: 1px solid #d92121;">
            <strong>⚠️ Member Database Error:</strong> @errorMessage
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5>@(isEditing ? "Edit Member Profile" : "Add New Member Profile")</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Member Name</label>
                    <input type="text" class="form-control" @bind="currentMember.Name" placeholder="e.g., Joey, Chandler, Your Name" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Favorite Music Genre</label>
                    <input type="text" class="form-control" @bind="currentMember.FavoriteGenre" placeholder="e.g., Rock, Pop, Jazz" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    @if (isEditing)
                    {
                        <button class="btn btn-success me-2 w-100" @onclick="SaveMember">Save</button>
                        <button class="btn btn-secondary w-100" @onclick="CancelEdit">Cancel</button>
                    }
                    else
                    {
                        <button class="btn btn-primary w-100" @onclick="SaveMember">Add Member</button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5>Registered Members</h5>
        </div>
        <div class="card-body p-0">
            @if (members == null && string.IsNullOrEmpty(errorMessage))
            {
                <p class="p-3 text-muted">Loading members...</p>
            }
            else if (members != null && !members.Any())
            {
                <p class="p-3 text-muted">No members added yet. Add yourself and your partner above!</p>
            }
            else if (members != null)
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Favorite Genre</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in members)
                        {
                            <tr>
                                <td>@member.Id</td>
                                <td><strong>@member.Name</strong></td>
                                <td><span class="badge bg-info text-dark">@member.FavoriteGenre</span></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-warning me-2" @onclick="() => EditMember(member)">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteMember(member.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private List<Member>? members;
    private Member currentMember = new();
    private bool isEditing = false;
    private string? errorMessage;

    private readonly string ApiUrl = "api/members";

    protected override async Task OnInitializedAsync()
    {
        await LoadMembers();
    }

    private async Task LoadMembers()
    {
        try
        {
            errorMessage = null;
            // GET request
            members = await Http.GetFromJsonAsync<List<Member>>(ApiUrl) ?? new List<Member>();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"API Error loading members: {ex.Message}");
        }
    }

    private async Task SaveMember()
    {
        if (string.IsNullOrWhiteSpace(currentMember.Name)) return;

        try
        {
            errorMessage = null;
            if (isEditing)
            {
                // PUT request (Update)
                await Http.PutAsJsonAsync($"{ApiUrl}/{currentMember.Id}", currentMember);
            }
            else
            {
                // POST request (Create)
                await Http.PostAsJsonAsync(ApiUrl, currentMember);
            }

            currentMember = new Member();
            isEditing = false;
            await LoadMembers();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"API Error saving member: {ex.Message}");
        }
    }

    private void EditMember(Member member)
    {
        currentMember = new Member { Id = member.Id, Name = member.Name, FavoriteGenre = member.FavoriteGenre };
        isEditing = true;
    }

    private void CancelEdit()
    {
        currentMember = new Member();
        isEditing = false;
    }

    private async Task DeleteMember(int id)
    {
        try
        {
            errorMessage = null;
            // DELETE request
            await Http.DeleteAsync($"{ApiUrl}/{id}");
            await LoadMembers();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"API Error deleting member: {ex.Message}");
        }
    }
}