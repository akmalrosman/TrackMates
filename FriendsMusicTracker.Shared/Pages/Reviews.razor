@page "/reviews"
@using FriendsMusicTracker.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject UserState UserState

<div class="container-fluid mt-4 text-white pb-5 px-md-4">

    @* Premium Header *@
    <div class="d-flex align-items-center mb-4 gap-3">
        <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center shadow-lg" style="width: 55px; height: 55px;">
            <span class="fs-3">💬</span>
        </div>
        <div>
            <h1 class="fw-bold mb-0 text-warning" style="letter-spacing: -1px; text-shadow: 0 0 15px rgba(255, 193, 7, 0.3);">Buzz & Reviews</h1>
            <p class="text-white-50 mb-0">Rate your crew's mixes and explore top-rated tracks.</p>
        </div>
    </div>

    @* Error banner *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="glass-error-banner mb-4 d-flex align-items-center gap-2 shadow-sm">
            <span class="fs-5">⚠️</span>
            <div>
                <strong>Network Error:</strong> @errorMessage
            </div>
        </div>
    }

    <div class="row g-4">

        @* Review Form & Community Feed *@
        <div class="col-12 col-lg-7 d-flex flex-column gap-4">

            @* Add/Edit Review Form *@
            <div class="glass-panel p-4 shadow-lg">
                <h5 class="fw-bold mb-4 text-white d-flex align-items-center gap-2">
                    @(isEditing ? "✏️ Edit Your Review" : "✍️ Write a Playlist Review")
                </h5>

                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label text-white-50 small fw-bold text-uppercase tracking-wide">Select Playlist to Review</label>
                        <select class="form-select custom-input" @onchange="OnPlaylistDropdownChanged">
                            <option value="0">-- Select Playlist --</option>
                            @foreach (var p in playlists)
                            {
                                <option value="@p.Id" selected="@(currentReview.PlaylistId == p.Id)">🎵 @p.PlaylistName (by @p.CuratorName)</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-white-50 small fw-bold text-uppercase tracking-wide">Rating</label>
                        <select class="form-select custom-input" @bind="currentReview.Rating">
                            <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                            <option value="4">⭐⭐⭐⭐ (4)</option>
                            <option value="3">⭐⭐⭐ (3)</option>
                            <option value="2">⭐⭐ (2)</option>
                            <option value="1">⭐ (1)</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label text-white-50 small fw-bold text-uppercase tracking-wide">Review Comment</label>
                        <input type="text" class="form-control custom-input" @bind="currentReview.Comment" placeholder="e.g., This playlist is an absolute vibe!" />
                    </div>

                    <div class="col-12 text-end mt-3 pt-3 border-top border-secondary border-opacity-25">
                        @if (isEditing)
                        {
                            <button class="btn btn-outline-light px-4 me-2 shadow-sm rounded-pill" @onclick="CancelEdit">Cancel</button>
                            <button class="btn btn-success px-4 fw-bold shadow-sm rounded-pill" @onclick="SaveReview">Save Changes</button>
                        }
                        else
                        {
                            <button class="btn btn-warning px-4 fw-bold shadow-sm custom-btn-glow rounded-pill text-dark" @onclick="SaveReview">
                                Submit Review
                            </button>
                        }
                    </div>
                </div>
            </div>

            @* Community Reviews Feed *@
            <div class="glass-panel p-3 shadow-lg d-flex flex-column flex-grow-1">
                <div class="d-flex justify-content-between align-items-center mb-3 px-2 border-bottom border-secondary border-opacity-25 pb-3">
                    <h5 class="fw-bold mb-0 text-white mt-1">🌍 Community Buzz</h5>
                </div>

                <div class="flex-grow-1 custom-scroll" style="max-height: 600px; overflow-y: auto;">
                    @if (reviews == null || !reviews.Any())
                    {
                        <div class="text-center p-5 text-white-50">
                            <span class="display-6 opacity-25 d-block mb-3">👻</span>
                            <p>No reviews left yet. Be the first to review a friend's playlist!</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var review in reviews)
                        {
                            string reviewerName = !string.IsNullOrEmpty(review.ReviewerName) ? review.ReviewerName : GetMemberName(review.MemberId);
                            bool isMyReview = (review.ReviewerName == UserState.MemberName || review.MemberId == UserState.MemberId);

                            <div class="track-row p-3 rounded-4 mb-3 d-flex flex-column gap-2 @(isMyReview ? "my-review-row" : "")">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="reviewer-avatar">
                                            @(reviewerName.Length > 0 ? reviewerName.Substring(0, 1).ToUpper() : "👤")
                                        </div>
                                        <div>
                                            <span class="fw-bold text-white d-block lh-1 mb-1">@reviewerName</span>
                                            <span class="text-white-50 small d-block lh-1" style="font-size: 0.75rem;">
                                                reviewed <strong class="text-warning">@GetPlaylistNameWithCurator(review.PlaylistId)</strong>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="text-warning small" style="letter-spacing: 2px;">
                                        @string.Concat(Enumerable.Repeat("⭐", review.Rating))
                                    </div>
                                </div>

                                <div class="text-white ps-5 pe-2 fst-italic mt-1" style="font-size: 0.95rem;">
                                    "@review.Comment"
                                </div>

                                @if (isMyReview)
                                {
                                    <div class="d-flex justify-content-end gap-2 mt-2 pt-2 border-top border-secondary border-opacity-25">
                                        <button class="btn btn-sm btn-outline-light border-0 action-btn text-white-50 hover-white px-2 py-0" @onclick="() => EditReview(review)">✏️ Edit</button>
                                        <button class="btn btn-sm btn-outline-danger border-0 action-btn text-white-50 hover-danger px-2 py-0" @onclick="() => DeleteReview(review.Id)">🗑️ Delete</button>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        @* Tracklist Preview & Player *@
        <div class="col-12 col-lg-5 d-flex flex-column gap-4">

            @* Tracklist Preview Panel *@
            <div class="glass-panel shadow-lg border-warning d-flex flex-column" style="max-height: 500px;">
                <div class="p-3 bg-dark bg-opacity-50 border-bottom border-warning d-flex justify-content-between align-items-center rounded-top-4">
                    <h5 class="mb-0 text-warning fw-bold">🗂 Tracklist Preview</h5>
                </div>

                <div class="p-2 flex-grow-1 custom-scroll" style="overflow-y: auto;">
                    @if (currentReview.PlaylistId == 0)
                    {
                        <div class="text-center p-5 text-white-50">
                            <span class="fs-1 opacity-25 d-block mb-3">👈</span>
                            <p class="small">Select a playlist from the dropdown menu to inspect its tracklist before writing your review!</p>
                        </div>
                    }
                    else if (!currentPlaylistSongs.Any())
                    {
                        <div class="text-center p-5 text-white-50">
                            <p class="small mb-0">This playlist doesn't contain any songs yet.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var ps in currentPlaylistSongs)
                        {
                            var matchedSong = GetSongDetails(ps.SongId);
                            if (matchedSong != null)
                            {
                                <div class="track-row p-2 px-3 rounded-3 d-flex justify-content-between align-items-center mb-2">
                                    <div class="text-truncate pe-3">
                                        <strong class="d-block text-white text-truncate mb-0" style="font-size: 0.9rem;">@matchedSong.Title</strong>
                                        <small class="text-white-50 text-truncate d-block" style="font-size: 0.75rem;">by @matchedSong.Artist</small>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(matchedSong.YoutubeUrl))
                                    {
                                        <button class="btn btn-sm btn-warning rounded-pill py-1 px-3 fw-bold shadow-sm play-mini-btn" @onclick="() => PlayTrack(matchedSong.YoutubeUrl)">
                                            <span style="font-size: 0.8rem;">▶ Play</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-25 border border-secondary text-white-50">No Audio</span>
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            </div>

            @* Sticky Player Panel *@
            @if (!string.IsNullOrEmpty(activeEmbedId))
            {
                <div class="glass-panel p-0 shadow-lg border-warning sticky-top player-card overflow-hidden fade-in" style="top: 20px;">
                    <div class="p-3 bg-black bg-opacity-50 border-bottom border-warning d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 text-warning fw-bold d-flex align-items-center gap-2">
                            <span class="pulse-dot"></span> Now Streaming
                        </h6>
                        <button type="button" class="btn-close btn-close-white shadow-none" @onclick="StopTrack"></button>
                    </div>
                    <div class="bg-black text-center">
                        <div class="ratio ratio-16x9">
                            <iframe src="https://www.youtube.com/embed/@activeEmbedId?autoplay=1"
                                    title="Playlist Audio Player"
                                    frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen>
                            </iframe>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div>
</div>

<style>
    .glass-panel {
        background: rgba(20, 20, 20, 0.4);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
    }

    .glass-error-banner {
        background: rgba(217, 33, 33, 0.15);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(217, 33, 33, 0.3);
        border-left: 4px solid #d92121;
        padding: 15px 20px;
        border-radius: 12px;
        color: #ffcccc;
    }

    .custom-input {
        background: rgba(0, 0, 0, 0.4) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        transition: all 0.3s ease;
    }

        .custom-input:focus {
            background: rgba(0, 0, 0, 0.8) !important;
            border-color: #ffc107 !important;
            box-shadow: 0 0 15px rgba(255, 193, 7, 0.2) !important;
        }

    .form-select.custom-input option {
        background: #1a1a1a;
        color: #fff;
    }

    .tracking-wide {
        letter-spacing: 0.8px;
    }

    .track-row {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.02);
        transition: all 0.2s ease;
    }

        .track-row:hover {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255, 193, 7, 0.2);
        }

    .my-review-row {
        border-left: 3px solid #ffc107;
        background: rgba(255, 193, 7, 0.03);
    }

    .reviewer-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4b1b4b 0%, #1e1b4b 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #ffc107;
        font-size: 0.9rem;
        border: 2px solid rgba(255,255,255,0.05);
    }

    .hover-white:hover {
        color: #fff !important;
        transform: scale(1.1);
    }

    .hover-danger:hover {
        color: #dc3545 !important;
        transform: scale(1.1);
    }

    .play-mini-btn {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .play-mini-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(255, 193, 7, 0.4) !important;
        }

    .custom-btn-glow {
        transition: all 0.3s;
    }

        .custom-btn-glow:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 193, 7, 0.4) !important;
        }

    .player-card {
        box-shadow: 0 10px 30px rgba(255, 193, 7, 0.15) !important;
    }

    .pulse-dot {
        width: 10px;
        height: 10px;
        background-color: #ffc107;
        border-radius: 50%;
        display: inline-block;
        animation: pulse-ring 2s infinite;
    }

    @@keyframes pulse-ring {
        0% {
            box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.7);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(255, 193, 7, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(255, 193, 7, 0);
        }
    }

    .fade-in {
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .custom-scroll::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scroll::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scroll::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }

        .custom-scroll::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 193, 7, 0.5);
        }
</style>

@code {
    private List<Review> reviews = new();
    private List<Member> members = new();
    private List<Playlist> playlists = new();
    private List<Song> globalSongs = new();
    private List<PlaylistSong> currentPlaylistSongs = new();

    private Review currentReview = new() { Rating = 5 };
    private bool isEditing = false;
    private string activeEmbedId = string.Empty;
    private string? errorMessage;

    private readonly string ApiUrlReviews = "api/reviews";
    private readonly string ApiUrlMembers = "api/members";
    private readonly string ApiUrlPlaylists = "api/playlists";
    private readonly string ApiUrlSongs = "api/songs";
    private readonly string ApiUrlPlaylistSongs = "api/playlistsongs";

    protected override async Task OnInitializedAsync()
    {
        await LoadAllData();
    }

    private async Task LoadAllData()
    {
        try
        {
            errorMessage = null;
            members = await Http.GetFromJsonAsync<List<Member>>(ApiUrlMembers) ?? new();
            playlists = await Http.GetFromJsonAsync<List<Playlist>>(ApiUrlPlaylists) ?? new();
            globalSongs = await Http.GetFromJsonAsync<List<Song>>(ApiUrlSongs) ?? new();
            reviews = await Http.GetFromJsonAsync<List<Review>>(ApiUrlReviews) ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"API Error loading data: {ex.Message}");
        }
    }

    private async Task LoadPlaylistSongs(int playlistId)
    {
        if (playlistId == 0)
        {
            currentPlaylistSongs.Clear();
            return;
        }

        try
        {
            errorMessage = null;
            currentPlaylistSongs = await Http.GetFromJsonAsync<List<PlaylistSong>>($"{ApiUrlPlaylistSongs}/playlist/{playlistId}") ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"API Error loading playlist songs: {ex.Message}");
        }
    }

    private async Task OnPlaylistDropdownChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            currentReview.PlaylistId = id;
            await LoadPlaylistSongs(id);
        }
    }

    private Song? GetSongDetails(int songId) =>
        globalSongs.FirstOrDefault(s => s.Id == songId);

    private string GetMemberName(int memberId) =>
        members.FirstOrDefault(m => m.Id == memberId)?.Name ?? "Unknown Member";

    private string GetPlaylistNameWithCurator(int playlistId)
    {
        var playlist = playlists.FirstOrDefault(p => p.Id == playlistId);
        if (playlist != null)
        {
            return $"{playlist.PlaylistName} (by {playlist.CuratorName})";
        }
        return "Unknown Playlist";
    }

    private async Task SaveReview()
    {
        currentReview.MemberId = UserState.MemberId;
        currentReview.ReviewerName = UserState.MemberName;

        if (currentReview.MemberId == 0 || currentReview.PlaylistId == 0 || string.IsNullOrWhiteSpace(currentReview.Comment)) return;

        try
        {
            errorMessage = null;
            if (isEditing)
            {
                await Http.PutAsJsonAsync($"{ApiUrlReviews}/{currentReview.Id}", currentReview);
            }
            else
            {
                await Http.PostAsJsonAsync(ApiUrlReviews, currentReview);
            }

            currentReview = new Review { Rating = 5 };
            currentPlaylistSongs.Clear();
            isEditing = false;
            await LoadAllData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"API Error saving review: {ex.Message}");
        }
    }

    private async Task EditReview(Review review)
    {
        currentReview = new Review
        {
            Id = review.Id,
            MemberId = review.MemberId,
            PlaylistId = review.PlaylistId,
            Rating = review.Rating,
            Comment = review.Comment,
            ReviewerName = review.ReviewerName
        };
        isEditing = true;

        await LoadPlaylistSongs(review.PlaylistId);
    }

    private void CancelEdit()
    {
        currentReview = new Review { Rating = 5 };
        currentPlaylistSongs.Clear();
        isEditing = false;
    }

    private async Task DeleteReview(int id)
    {
        try
        {
            errorMessage = null;
            await Http.DeleteAsync($"{ApiUrlReviews}/{id}");
            await LoadAllData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"API Error deleting review: {ex.Message}");
        }
    }

    private void PlayTrack(string url)
    {
        activeEmbedId = string.Empty;

        if (url.Contains("v="))
        {
            var parts = url.Split("v=");
            if (parts.Length > 1) activeEmbedId = parts[1].Split('&')[0];
        }
        else if (url.Contains("youtu.be/"))
        {
            var parts = url.Split("youtu.be/");
            if (parts.Length > 1) activeEmbedId = parts[1].Split('?')[0];
        }
    }

    private void StopTrack() => activeEmbedId = string.Empty;
}